rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Audio calls ─────────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (resource == null
          || request.auth.uid == resource.data.callerId
          || request.auth.uid == resource.data.calleeId);
    }
    match /calls/{callId}/candidates/{candidateId} {
      allow read, write: if request.auth != null;
    }

    // ── Video calls ──────────────────────────────────────────────────────────
    match /video_calls/{callId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (resource == null
          || request.auth.uid == resource.data.callerId
          || request.auth.uid == resource.data.calleeId);
    }
    match /video_calls/{callId}/candidates/{candidateId} {
      allow read, write: if request.auth != null;
    }

    // ── Catch-all for other collections (users, chats, messages, etc.) ──────
    // This restores the ability for the app to function if you haven't written
    // strict rules for every other collection yet.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}
